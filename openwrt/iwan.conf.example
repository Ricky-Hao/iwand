# Panabit iWAN SD-WAN Client Configuration
#
# The section header [name] sets the TUN interface name.
# All fields are required unless noted otherwise.

[iwan0]
server=10.0.0.1
username=myuser
password=mypassword
port=4567
mtu=1400
encrypt=0

# Optional: segment routing (multi-hop only)
# srlinks=1.2.3.4,5.6.7.8
# srpassword=secret
# srencryptmode=1

# Optional: hook scripts (called with: event tun_name ip mtu dns0 dns1)
# up_script=/etc/iwan/up.sh
# down_script=/etc/iwan/down.sh
